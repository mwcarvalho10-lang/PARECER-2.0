rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['appData', 'skills', 'pins', 'teachers', 'docConfig', 'updatedAt']) &&
             (data.get('appData', '') is string) &&
             (data.get('skills', '') is string) &&
             (data.get('pins', '') is string) &&
             (data.get('teachers', '') is string) &&
             (data.get('docConfig', '') is string) &&
             (data.get('updatedAt', request.time) == request.time);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
